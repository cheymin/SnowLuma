# Ignore files generated by Claude
.claude

# Node / pnpm / monorepo
node_modules/
**/node_modules/
dist/
**/dist/
.vscode/
.idea/
.pnpm-store/

/config/
/data/
# per-package runtime data dirs (e.g. packages/core/data/<uin>/*.db written by
# IdentityService during tests) — not just the root /data/
**/data/
logs/

# macOS metadata
.DS_Store

# test coverage output
coverage/

# Vendored QQ NT debs (kept locally for offline builds; GitHub's 100 MB
# per-file cap blocks them from being committed — fetched at build time
# from the AUR beta CDN path instead, see Dockerfile).
qq/*.deb
